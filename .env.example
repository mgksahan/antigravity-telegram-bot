# Antigravity Telegram Bot configuration template
# Rename this file to '.env' and populate with your credentials.

# Your Telegram Bot Token obtained from BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Your actual numeric Telegram User ID (e.g., 987654321)
# The bot will silently ignore all messages from any other user or chat.
ALLOWED_USER_ID=123456789
